{
  "name": "Owlhacks Deploy Now Workshop",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },
  "forwardPorts": [3000, 5173, 8000, 8080, 80],
  "portsAttributes": {
    "5173": {
      "label": "Vite Dev Server"
    },
    "3000": {
      "label": "Node.js App"
    },
    "8000": {
      "label": "PHP Dev Server"
    }
  }
}
