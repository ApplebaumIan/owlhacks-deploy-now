	     # ---- Build stage: install Laravel with Composer
	     FROM php:8.2-cli AS builder
	     ENV DEBIAN_FRONTEND=noninteractive

# Install deps and build mbstring (needs oniguruma headers)
RUN apt-get update \
 && apt-get install -y --no-install-recommends unzip libonig-dev \
  && docker-php-ext-install mbstring \
   && rm -rf /var/lib/apt/lists/*

# Composer
COPY --from=composer:2 /usr/bin/composer /usr/bin/composer

# Create project (no dev deps to keep it light)
WORKDIR /app
ARG LARAVEL_VERSION="^11.0"
RUN composer create-project --no-dev --prefer-dist laravel/laravel:"${LARAVEL_VERSION}" .
COPY . .
# Optimize autoload and generate app key
ENV APP_ENV=production
RUN php artisan key:generate --ansi && php artisan config:clear && php artisan route:clear && php artisan view:clear

# ---- Runtime stage: tiny PHP container serving /public on :8080
FROM php:8.2-cli

# Install only what we need (mbstring commonly used by Laravel)
RUN apt-get update && apt-get install -y unzip \
  && docker-php-ext-install mbstring \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY --from=builder /app /app

# Healthcheck (simple: ping the root)
HEALTHCHECK --interval=30s --timeout=3s CMD php -r "try{ echo file_get_contents('http://127.0.0.1:8080')?0:1; }catch(Exception $e){ exit(1);}";

# Laravel served by PHP's built-in server (fine for workshop demos)
EXPOSE 8080
CMD ["php", "-S", "0.0.0.0:8080", "-t", "public", "public/index.php"]













































